[KEYS]
; Get your OpenRouter API key here: https://openrouter.ai/keys
OPENROUTER_API_KEY = your_openrouter_api_key_here
; Contact https://telegram.me/BotFather on Telegram to get your bot token
TELEGRAM_BOT_TOKEN = your_telegram_token_here
; Discord bot token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN = your_discord_token_here
; Get your api-football.com key (free tier = 100 requests/day) here:
; https://www.api-football.com/
API_FOOTBALL_KEY = your_api_football_key_here
; Numeric team ID from api-football (browse at https://dashboard.api-football.com/)
TEAM_ID = your_team_id_here
; Display name of the team (used in messages and AI prompts)
TEAM_NAME = your_team_name_here
; Comma-separated list of league IDs to monitor for this team
; Example: 39 for English Premier League, 2 for UEFA Champions League, etc.
LEAGUE_IDS = 1,2,3
; Season ID (4-digit year). For 2025-2026 season -> 2025
SEASON_ID = your_season_id_here

[OPTIONS]
; Enable/disable Telegram bot
USE_TELEGRAM = true
; Enable/disable Discord bot
USE_DISCORD = true
; Set to true if you have a paid api-football plan (more frequent live polling)
IS_PAID_API = false
; Track and log AI API costs in logs
ENABLE_COST_TRACKING = true

[API_MODELS]
; Main model for match analysis (OpenRouter model slug, e.g., minimax/minimax-m3,
; openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001)
MAIN_MODEL = minimax/minimax-m3
; Model for translations (can be the same or different)
TRANSLATION_MODEL = minimax/minimax-m3

[API_PRICING]
; Cost per 1 million input tokens in USD (adjust for your model / provider)
; minimax/minimax-m3 on OpenRouter: $0.30 in / $1.20 out per 1M tokens
INPUT_COST_PER_1M_TOKENS = 0.30
; Cost per 1 million output tokens in USD (adjust for your model / provider)
OUTPUT_COST_PER_1M_TOKENS = 1.20
; Cache discount percentage (e.g., 75 for 75% discount on cached input)
CACHE_DISCOUNT_PERCENTAGE = 75

[SERVER]
; Server timezone (used to schedule the daily match check at 09:00)
TIMEZONE = Europe/Paris

[LANGUAGES]
; Output language. Write the language name in lowercase English.
; If not "french", messages will be translated by the LLM (extra tokens consumed).
LANGUAGE = french

[LEAGUE_TYPES]
; OPTIONAL — Comma-separated league IDs that may go to extra time (cups, knockout phases).
; Each ID listed here uses an extended live-polling budget (+30 min vs regular championship).
; Leagues NOT listed are treated as regular championships (no extra time).
; Leave empty if all your leagues in LEAGUE_IDS are regular championships.
; Example for monitoring a national cup with possible extra time: LEAGUES_WITH_EXTRA_TIME = 209
LEAGUES_WITH_EXTRA_TIME =
